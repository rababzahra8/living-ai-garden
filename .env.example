# Copy to .env and fill in your values (never commit .env)

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key
SUPABASE_PROJECT_ID=your_project_id

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key
VITE_SUPABASE_PROJECT_ID=your_project_id

# Used for auth email redirects (must match Supabase redirect allowlist)
VITE_APP_URL=http://localhost:8080

# Server-only — Gardener chat (do not expose to the browser)
OPENAI_API_KEY=your_openai_api_key

# --- Cloudflare Pages / Workers (set in dashboard → Settings → Environment variables) ---
# Build-time (required for client bundle):
#   VITE_SUPABASE_URL
#   VITE_SUPABASE_PUBLISHABLE_KEY
#   VITE_APP_URL=https://your-project.pages.dev
#
# Runtime (required for SSR + chat):
#   SUPABASE_URL
#   SUPABASE_PUBLISHABLE_KEY
#   OPENAI_API_KEY
#
# Deploy step (npx nitro deploy --prebuilt):
#   CLOUDFLARE_API_TOKEN
#   CLOUDFLARE_ACCOUNT_ID
