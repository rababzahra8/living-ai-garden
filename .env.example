# Copy to .env for local development (never commit .env)

# Browser bundle (Vite)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key
VITE_APP_URL=http://localhost:8080

# Server (SSR + chat)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key
OPENAI_API_KEY=your_openai_api_key

# Free fallbacks when OpenAI quota/rate limit is hit (recommended)
# Groq: https://console.groq.com
GROQ_API_KEY=
# Gemini: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# --- Cloudflare (living-ai-garden worker) — TWO places ---
#
# A) Settings → Variables and secrets  ← RUNTIME (server / chat)
#    SUPABASE_URL, SUPABASE_PUBLISHABLE_KEY, OPENAI_API_KEY
#    GROQ_API_KEY, GEMINI_API_KEY (optional but recommended)
#
# B) Settings → Builds → Build variables  ← BUILD TIME (browser)
#    VITE_SUPABASE_URL, VITE_SUPABASE_PUBLISHABLE_KEY, VITE_APP_URL
#
# Build variables do NOT carry over to runtime. You need both.
