# Copy to .env for local development (never commit .env)

# Browser bundle (Vite)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key
VITE_APP_URL=http://localhost:8080

# Server (SSR + chat)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key
OPENAI_API_KEY=your_openai_api_key

# Free fallbacks when OpenAI quota/rate limit is hit (recommended)
# Groq: https://console.groq.com
GROQ_API_KEY=
# Gemini: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# --- Cloudflare (living-ai-garden worker) ---
#
# ONE-TIME setup (then deploys keep your keys):
#   1. npm run cf:secrets     ← uploads runtime secrets from this file
#   2. Cloudflare → Builds → Build variables (browser bundle, set once):
#        VITE_SUPABASE_URL, VITE_SUPABASE_PUBLISHABLE_KEY, VITE_APP_URL
#
# Optional auto-sync on every git deploy: add the same SUPABASE_* / *_API_KEY
# vars as encrypted Build variables, then set Deploy command to:
#   npm run cf:secrets:ci && npx nitro deploy --prebuilt
#
# wrangler.toml sets keep_vars = true so deploys do not wipe dashboard secrets.
