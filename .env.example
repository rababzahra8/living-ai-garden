# Copy to .env and fill in your values (never commit .env)

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key
SUPABASE_PROJECT_ID=your_project_id

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key
VITE_SUPABASE_PROJECT_ID=your_project_id

# Used for auth email redirects (must match Supabase redirect allowlist)
VITE_APP_URL=http://localhost:8080
# Production example:
# VITE_APP_URL=https://living-ai-garden.r-rababzahra888.workers.dev

# Server-only — Gardener chat (do not expose to the browser)
OPENAI_API_KEY=your_openai_api_key

# --- Cloudflare Workers Builds (dashboard → Workers → your worker → Settings) ---
#
# Build variables (Settings → Builds → Build variables):
#   VITE_SUPABASE_URL=https://your-project.supabase.co
#   VITE_SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key
#   VITE_APP_URL=https://living-ai-garden.r-rababzahra888.workers.dev
#
# Runtime variables (Settings → Variables and Secrets):
#   SUPABASE_URL=https://your-project.supabase.co
#   SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key
#   OPENAI_API_KEY=your_openai_api_key
#
# Deploy step (Build command: npm run build, Deploy: npx nitro deploy --prebuilt):
#   CLOUDFLARE_API_TOKEN
#   CLOUDFLARE_ACCOUNT_ID
#
# After changing build variables, clear the build cache once and redeploy.
