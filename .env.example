# Copy to .env for local development (never commit .env)

# Browser bundle (Vite)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key
VITE_APP_URL=http://localhost:8080

# Server (SSR + chat)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key
OPENAI_API_KEY=your_openai_api_key

# --- Cloudflare (living-ai-garden worker) ---
#
# Build variables  → Settings → Builds
#   VITE_SUPABASE_URL, VITE_SUPABASE_PUBLISHABLE_KEY, VITE_APP_URL
#
# Runtime secrets → Settings → Variables and Secrets
#   SUPABASE_URL, SUPABASE_PUBLISHABLE_KEY, OPENAI_API_KEY
#
# Deploy: npm run build && npx nitro deploy --prebuilt
